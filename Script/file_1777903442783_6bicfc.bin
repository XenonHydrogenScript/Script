closeCloudGallery.onclick = hideCloudGallery;

saveGithubBtn.onclick = saveGithubConfig;
cancelGithubBtn.onclick = hideGitHubConfig;
testGithubBtn.onclick = testGitHubConnection;
reconfigGithubBtn.onclick = reconfigureGitHub;

githubConfigOverlay.addEventListener('click', (e) => {
  if (e.target === githubConfigOverlay) {
    hideGitHubConfig();
  }
});

cloudGalleryOverlay.addEventListener('click', (e) => {
  if (e.target === cloudGalleryOverlay) {
    hideCloudGallery();
  }
});

// 初始的确认按钮点击事件
alertConfirm.onclick = hideAlert;
// 初始的遮罩层点击事件
alertOverlay.onclick = hideAlert;

document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    if (customAlert.classList.contains('active')) {
      hideAlert();
    }
    if (githubConfigOverlay.classList.contains('show')) {
      hideGitHubConfig();
    }
    if (cloudGalleryOverlay.classList.contains('show')) {
      hideCloudGallery();
    }
  }
});

uploadBtn.onclick = () => fileInput.click();

fileInput.onchange = e => {
  const files = [...e.target.files];
  
  if (files.length === 0) {
    showAlert('请选择文件！\n\n支持的文件类型：\n• 图片：JPG、PNG、GIF、WebP、SVG\n• 视频：MP4、WebM、OGG、MOV、AVI\n• 代码：JS、Python、Lua、HTML、CSS等\n• 文档：PDF、TXT、MD、JSON等\n• 压缩包：ZIP、RAR、7Z等\n• 音频：MP3、WAV、OGG等\n• 其他：几乎所有文件类型');
    return;
  }

  if (files.length > 20) {
    showAlert('一次最多只能上传20个文件！\n\n请减少文件数量后重试。');
    return;
  }

  files.forEach(file => {
    const url = URL.createObjectURL(file);
    const fileType = getFileType(file);

    const item = document.createElement('div');
    item.className = 'item';
    
    if (fileType === 'image') {
      item.innerHTML = `
        <img src="${url}">
        <div class="delete-pop">
          <button class="del-btn">删除</button>
        </div>
      `;
    } else if (fileType === 'video') {
      item.innerHTML = `
        <video src="${url}" muted loop autoplay playsinline></video>
        <div class="delete-pop">
          <button class="del-btn">删除</button>
        </div>
      `;
    } else {
      const icon = getFileIcon(file.name);
      const fileTypeName = '文件';
      const fileSize = formatFileSize(file.size);
      
      item.innerHTML = `
        <div class="code-preview">
          <div class="file-type-icon">${icon}</div>
          <div class="file-name">${file.name} (${fileSize})</div>
          <div style="text-align: center; padding: 20px; color: #888;">
            ${fileTypeName}<br>
            <small>${fileSize}</small>
          </div>
        </div>
        <div class="delete-pop">
          <button class="del-btn">删除</button>
        </div>
      `;
    }

    uploadedFiles.push({
      url,
      file,
      fileType
    });

    bindLongPress(item);

    item.querySelector('.del-btn').onclick = () => {
      const index = uploadedFiles.findIndex(f => f.url === url);
      if (index > -1) {
        uploadedFiles.splice(index, 1);
      }
      URL.revokeObjectURL(url);
      item.remove();
      refreshAllImgs();
    };

    boxList[boxIndex].appendChild(item);
    boxIndex = (boxIndex + 1) % boxList.length;
  });

  boxList.forEach(box => {
    setTimeout(() => box.scrollLeft = box.scrollWidth, 100);
  });

  refreshAllImgs();
  
  if (files.length > 0) {
    setTimeout(() => {
      showAlert(`成功添加 ${files.length} 个文件到展示架！`);
    }, 300);
  }
  
  fileInput.value = '';
};

let timer = null;
function bindLongPress(el) {
  el.addEventListener('touchstart', () => {
    timer = setTimeout(() => {
      closeAll();
      el.querySelector('.delete-pop').style.display = 'block';
    }, 500);
  });
  el.addEventListener('touchend', () => clearTimeout(timer));
  el.addEventListener('touchmove', () => clearTimeout(timer));
}

function closeAll() {
  document.querySelectorAll('.delete-pop').forEach(p => p.style.display = 'none');
}

function refreshAllImgs() {
  imgColors = [];
  document.querySelectorAll('img').forEach(img => {
    img.onload = async () => {
      ctx.drawImage(img, 0, 0, 1, 1);
      let d = ctx.getImageData(0, 0, 1, 1).data;
      imgColors.push({ img, color: { r: d[0], g: d[1], b: d[2] } });
    };
  });
  
  document.querySelectorAll('video').forEach(video => {
    video.addEventListener('loadeddata', () => {
      try {
        ctx.drawImage(video, 0, 0, 1, 1);
        let d = ctx.getImageData(0, 0, 1, 1).data;
        imgColors.push({ img: video, color: { r: d[0], g: d[1], b: d[2] } });
      } catch(e) {
        // 跨域或安全限制时跳过
      }
    });
  });
}

function getTextColor(r, g, b) {
  return (r * 299 + g * 587 + b * 114) / 1000 > 128 ? '#000' : '#fff';
}

function updateBtnColor() {
  let max = 0, visible = null;
  imgColors.forEach(({ img, color }) => {
    let rect = img.getBoundingClientRect();
    let area = Math.max(0,
      Math.min(rect.bottom, innerHeight) - Math.max(rect.top, 0)
    ) * Math.max(0,
      Math.min(rect.right, innerWidth) - Math.max(rect.left, 0)
    );
    if (area > max) { max = area; visible = color; }
  });

  if (visible) {
    uploadBtn.style.background = `rgba(${visible.r}, ${visible.g}, ${visible.b}, 0.3)`;
    uploadBtn.style.color = getTextColor(visible.r, visible.g, visible.b);
  }
}

window.addEventListener('scroll', () => {
  closeAll();
  updateBtnColor();
});

// 双指手势缩放
let start = 0, scale = 1;

function dist(e) {
  let [a, b] = e.touches;
  return Math.hypot(b.clientX - a.clientX, b.clientY - a.clientY);
}

document.addEventListener('touchstart', e => {
  if (e.touches.length === 2) start = dist(e);
});

document.addEventListener('touchmove', e => {
  closeAll();
  if (e.touches.length === 2) {
    e.preventDefault();
    let now = dist(e);
    scale *= now / start;
    scale = Math.max(0.7, Math.min(1.3, scale));
    document.getElementById('scaleWrap').style.transform = `scale(${scale})`;
    start = now;
  }
}, { passive: false });

// 隐藏标题
window.addEventListener('load', () => {
  loadGithubConfig();
  // 确保标题被清空
  document.title = '';
  // 定期检查并清空标题
  setInterval(() => {
    if (document.title.trim() !== '') {
      document.title = '';
    }
  }, 100);
});
</script>

</body>
</html>
